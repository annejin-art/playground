# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
# Download from Google Cloud Console > APIs & Services > Credentials
# Create an OAuth 2.0 Client ID (Application type: Desktop app)
GMAIL_CREDENTIALS_FILE=credentials.json

# Auto-generated on first run — do not share
GMAIL_TOKEN_FILE=token.json

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Digest ────────────────────────────────────────────────────────────────────
# Where to send the daily digest (your inbox)
DIGEST_RECIPIENT=annejin2021@gmail.com

# 24-hour time HH:MM
DIGEST_TIME=07:00

# pytz timezone name — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York

# ── Storage ───────────────────────────────────────────────────────────────────
DATABASE_PATH=newsletters.db

# ── Newsletter detection ──────────────────────────────────────────────────────
# The address you forward/subscribe newsletters to
SUBSCRIPTION_EMAIL=annejin2021+subs@gmail.com

# Top-level Gmail label used to organise newsletters
GMAIL_LABEL_PREFIX=Newsletters
